# .env.production.example — Template de variáveis de ambiente para produção
#
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.production.example .env
#   2. Preencha TODOS os valores marcados com <...>
#   3. Nunca versione o arquivo .env (já está no .gitignore)
#
# Gerar SECRET_KEY segura:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"

# =============================================================================
# OBRIGATÓRIAS
# =============================================================================

# Chave secreta Flask — mínimo 32 caracteres, nunca o valor padrão
SECRET_KEY=<gere-com-o-comando-acima>

# URL de conexão com o banco de dados
DATABASE_URL=postgresql://triagem:<POSTGRES_PASSWORD>@db:5432/triagem_db
POSTGRES_DB=triagem_db
POSTGRES_USER=triagem
POSTGRES_PASSWORD=<senha-forte-aqui>

# URL do Redis
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_PASSWORD=<senha-redis-aqui>

# Forçar HTTPS (True quando atrás de proxy reverso com SSL)
FORCE_HTTPS=True

# =============================================================================
# ARMAZENAMENTO DE FOTOS
# =============================================================================
# STORAGE_BACKEND=local  → salva no volume Docker (padrão, sem configuração extra)
# STORAGE_BACKEND=s3     → envia para bucket S3 (recomendado para produção)

STORAGE_BACKEND=local
# STORAGE_BACKEND=s3

# Pasta de uploads — usada apenas quando STORAGE_BACKEND=local
UPLOAD_FOLDER=/var/app/uploads

# Configurações S3 — necessárias apenas quando STORAGE_BACKEND=s3
# Compatível com AWS S3, MinIO, DigitalOcean Spaces, Cloudflare R2, etc.
# S3_BUCKET=<nome-do-bucket>
# S3_REGION=us-east-1
# S3_ACCESS_KEY=<access-key-id>
# S3_SECRET_KEY=<secret-access-key>
# S3_ENDPOINT=          # deixe vazio para AWS; para MinIO/Spaces: https://endpoint.url
# S3_SIGNED_URL_TTL=3600  # expiração das URLs assinadas em segundos

# =============================================================================
# E-MAIL (opcional)
# =============================================================================
# Se não configurado, links de confirmação aparecem apenas no log do servidor.

# SMTP_HOST=smtp.seu-provedor.com
# SMTP_PORT=587
# SMTP_USER=usuario@exemplo.com
# SMTP_PASSWORD=<senha-smtp>
# SMTP_USE_TLS=True
# MAIL_FROM=noreply@exemplo.com

# =============================================================================
# CELERY (opcional — usa REDIS_URL por padrão)
# =============================================================================
# CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
# CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# =============================================================================
# BANCO DE DADOS — CONNECTION POOL
# =============================================================================
# Ajuste para 50-100 usuários simultâneos
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=40
# DB_POOL_RECYCLE=3600
# DB_POOL_TIMEOUT=30
