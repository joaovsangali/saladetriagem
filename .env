# ============================================================
# .env.example — copy to .env and fill in your values
# ============================================================

# ------------------------------------------------------------
# Flask / Application
# ------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=FA_UpQoG-6dEa041rlHlolLczrSaZlb0kK0grp1BLKY2_mJ_F08rIVSfruH5xK_1Hk6fQQ4y20BWo1g0lg_chA
REDIS_PASSWORD=jorXanHCnFXYYm8qa7EhHhbLUjntho_Ch-GRJ5s-SiUhsxJ2e4YmkFhMl60JM5Nl4ALKsUSxx3DlYwdWFTudiA

FLASK_ENV=production
FLASK_DEBUG=0
FORCE_HTTPS=true

# ------------------------------------------------------------
# Database  (choose one)
# ------------------------------------------------------------
# Production (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/triagem_db

# Development fallback (SQLite)
# DATABASE_URL=sqlite:///triagem.db

# ------------------------------------------------------------
# Redis  (optional — falls back to in-memory if not set)
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# Celery  (optional — falls back to threading daemon if not set)
# ------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ------------------------------------------------------------
# Object Storage  (optional — falls back to local filesystem)
# ------------------------------------------------------------
# STORAGE_BACKEND=s3
# S3_BUCKET=triagem-photos
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_SIGNED_URL_TTL=3600

# Local filesystem fallback
STORAGE_BACKEND=local
UPLOAD_FOLDER=/var/app/uploads

# ------------------------------------------------------------
# Gunicorn
# ------------------------------------------------------------
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
GUNICORN_LOG_LEVEL=info

# ------------------------------------------------------------
# E-mail (optional — for user registration confirmation)
# ------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=True
MAIL_FROM=noreply@example.com

# ------------------------------------------------------------
# Feature flags
# ------------------------------------------------------------
REQUIRE_CPF_FOR_SIGNUP=False
